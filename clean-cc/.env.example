# Any non-empty string; Claude Code sends it as the bearer token to LiteLLM.
LITELLM_MASTER_KEY=sk-eval-local

# AWS Bedrock temporary SSO creds (refresh via `aws sso login`, then export).
# AWS_REGION_NAME must hold the Claude Sonnet 4.6 inference profile.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION_NAME=eu-central-1
