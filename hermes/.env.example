# Match your host user so files written to the mounts stay writable.
HERMES_UID=1000
HERMES_GID=1000

# AWS Bedrock temporary SSO creds (refresh via `aws sso login`, then export).
# Injected as static creds so boto3 never writes the read-only SSO cache.
# AWS_REGION_NAME must hold the Claude Sonnet 4.6 inference profile.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION_NAME=eu-central-1
