# -------------------------------------------------------
# hermes-home/.gitignore
# Track ONLY user-specific changes. Everything below is
# regenerated by the container at startup or is runtime
# state that has no value in version control.
# -------------------------------------------------------

# --- Caches / model metadata ---
cache/
*.json
!cron/jobs.json

# --- Binaries ---
bin/

# --- Runtime / ephemeral state ---
*.lock
*.db
*.db-shm
*.db-wal
state.db*
kanban.db*
auth.lock
gateway_state.json
channel_directory.json
.hermes_history
.update_check
.install_method

# --- Logs ---
logs/
*.log

# --- Sessions & request dumps ---
sessions/

# --- Bundled skills (container regenerates all of these) ---
# Any NEW skill category you create outside these dirs WILL be tracked.
skills/apple/
skills/autonomous-ai-agents/
skills/creative/
skills/data-science/
skills/devops/
skills/dogfood/
skills/email/
skills/github/
skills/index-cache/
skills/media/
skills/mlops/
skills/note-taking/
skills/productivity/
skills/research/
skills/smart-home/
skills/social-media/
skills/software-development/
skills/yuanbao/

# Skills internal caches / backups (not user content)
skills/.curator_backups/
skills/.curator_state
skills/.usage.json
skills/.usage.json.lock

# --- Credentials / secrets (mount from ~/.aws, not tracked) ---
.aws/
.env
.env.bak*

# --- Config backups created by hermes update ---
config.yaml.bak*

# --- Other runtime dirs ---
workspace/
home/
skins/
pairing/
platforms/
cron/output/
cron/.jobs.lock
cron/.tick.lock

.cache
.clean_shutdown
.gateway_pid